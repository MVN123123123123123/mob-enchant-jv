{
	"schemaVersion": 1,
	"id": "entity-enchant",
	"version": "${version}",
	"name": "Entity enchant",
	"description": "enchant entity",
	"authors": [
		"discord:phobochienxu"
	],
	"contact": {
		"homepage": "none",
		"sources": "https://github.com/MVN123123123123123/mob-enchant-jv"
	},
	"license": "CC0-1.0",
	"icon": "assets/mob-enchant/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "com.mobenchant.mvn123123123123123.MobEnchant",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "com.mobenchant.mvn123123123123123.client.MobEnchantClient",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "com.mobenchant.mvn123123123123123.client.MobEnchantDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"mob-enchant.mixins.json",
		{
			"config": "mob-enchant.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}